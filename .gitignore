# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Virtual env
.venv/
venv/

# IDE
# .idea/ is intentionally NOT ignored: PyCharm maintains its own
# .idea/.gitignore which only excludes workspace.xml, shelf/ and
# httpRequests/ (the per-user state). The shared team config
# (modules.xml, misc.xml, vcs.xml, *.iml, inspectionProfiles/) is
# safe to commit — all paths use $PROJECT_DIR$ / $MODULE_DIR$ macros.
.vscode/

# OS
.DS_Store

# Claude Code worktrees (isolated agent runs, should not be committed)
.claude/

# CatBoost training artifacts
catboost_info/

# Backend — generated SQLite database (regenerate via backend/scripts/build_database.py)
backend/reefer.db
backend/reefer.db.zip

# Web — build output and node_modules
web/dist/
web/node_modules/
web/*.log
