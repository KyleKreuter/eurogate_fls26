# Eurogate FLS26 web frontend environment variables
#
# Copy this file to .env and fill in the values.
# .env is gitignored and MUST NOT be committed.

# Mapbox GL access token (public, pk.*) — URL-restrict to your deploy hostnames
# Get one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# Optional: override backend URL for prod builds (default: "" = same origin / dev proxy)
# VITE_API_BASE=https://api.eurogate.example.com
